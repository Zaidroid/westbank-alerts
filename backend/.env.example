# ── Telegram ──────────────────────────────────────────────────────────────────
# Get API_ID and API_HASH from https://my.telegram.org
# Log in → API development tools → Create app
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_PHONE=+970XXXXXXXXX

# SESSION (pick one method)
#
# Cloud method — StringSession (recommended for Fly.io):
#   Run `python generate_session.py` locally to generate this string.
#   Then set it in Fly.io: flyctl secrets set TELEGRAM_SESSION_STRING='...'
TELEGRAM_SESSION_STRING=
#
# File method — used when TELEGRAM_SESSION_STRING is empty:
#   Session file stored at TELEGRAM_SESSION_DIR/wb_alerts.session
#   Only works if the directory is on a persistent volume.
TELEGRAM_SESSION_DIR=/data/session

# Comma-separated channel usernames WITHOUT the @ symbol
# Example: QudsN,wafanews,palinfo,nablus_now
TELEGRAM_CHANNELS=channel1,channel2,channel3

# ── Location priority ─────────────────────────────────────────────────────────
# Alerts mentioning this city will be classified as CRITICAL severity
YOUR_CITY_AR=نابلس
YOUR_CITY_EN=Nablus

# ── API security ──────────────────────────────────────────────────────────────
# Used in X-API-Key header for write endpoints (admin, webhooks)
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=change-this-to-a-random-strong-secret

# ── Storage ───────────────────────────────────────────────────────────────────
DB_PATH=/data/alerts.db
MAX_ALERTS_STORED=20000
